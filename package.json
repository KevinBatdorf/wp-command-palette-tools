{
	"name": "wpcp-tools",
	"version": "0.1.0",
	"type": "module",
	"description": "A collection of productivity tools for the WordPress Command Palette",
	"author": "Kevin Batdorf",
	"license": "GPL-2.0-or-later",
	"main": "build/index.js",
	"scripts": {
		"build": "tsc && biome check && wp-scripts build",
		"lint": "biome check",
		"lint:fix": "biome check --write",
		"packages-update": "wp-scripts packages-update",
		"plugin-zip": "wp-scripts plugin-zip",
		"start": "wp-scripts start",
		"start:hot": "wp-scripts start --hot",
		"test:e2e": "node scripts/run-e2e.mjs",
		"test:e2e:ui": "npx playwright test --ui"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.2.5",
		"@playwright/test": "^1.55.1",
		"@types/canvas-confetti": "^1.6.2",
		"@types/wordpress__block-editor": "^11.5.17",
		"@types/wordpress__blocks": "^12.5.18",
		"@types/wordpress__edit-post": "^7.5.4",
		"@wordpress/e2e-test-utils-playwright": "^1.32.0",
		"@wordpress/scripts": "^30.25.0",
		"@wp-playground/cli": "^3.0.8",
		"typescript": "^5.9.3"
	},
	"dependencies": {
		"@tailwindcss/postcss": "^4.1.14",
		"@wordpress/block-editor": "^15.5.0",
		"@wordpress/blocks": "^15.5.0",
		"@wordpress/commands": "^1.42.0",
		"@wordpress/edit-post": "^8.42.0",
		"@wordpress/element": "^6.32.0",
		"@wordpress/i18n": "^6.5.0",
		"@wordpress/icons": "^12.0.0",
		"@wordpress/plugins": "^7.42.0",
		"canvas-confetti": "^1.9.0",
		"colord": "^2.9.3",
		"copy-to-clipboard": "^3.3.3",
		"mathjs": "^12.0.0",
		"postcss": "^8.5.6",
		"postcss-prefix-selector": "^2.1.0",
		"tailwindcss": "^4.1.14"
	}
}
